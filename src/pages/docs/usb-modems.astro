            <p class="card-description">amd64 &middot; .tar.gz</p>
        </a>
        <a href="https://github.com/JimScope/vendel/releases/latest/download/vendel-modem-agent_linux_arm64.tar.gz" class="card card-default no-underline hover:border-[var(--color-accent)]" style="transition: border-color 0.2s">
            <h4 class="card-title">Linux ARM64</h4>
            <p class="card-description">arm64 &middot; .tar.gz</p>
        </a>
        <a href="https://github.com/JimScope/vendel/releases/latest/download/vendel-modem-agent_linux_arm.tar.gz" class="card card-default no-underline hover:border-[var(--color-accent)]" style="transition: border-color 0.2s">
