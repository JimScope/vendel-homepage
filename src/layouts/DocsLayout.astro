---
import '../styles/global.css'
import WaitlistModal from '../components/WaitlistModal.astro'

interface Props {
  title: string
  description?: string
}

const { title, description } = Astro.props

const sidebar = [
  {
    title: 'Getting Started',
    items: [
      { title: 'Introduction', href: '/docs/introduction' },
      { title: 'Quick Start', href: '/docs/quickstart' },
      { title: 'Installation', href: '/docs/installation' },
    ]
  },
  {
    title: 'Devices',
    items: [
      { title: 'Android App', href: '/docs/android-app' },
      { title: 'USB Modems', href: '/docs/usb-modems' },
      { title: 'Device Management', href: '/docs/device-management' },
    ]
  },
  {
    title: 'Features',
    items: [
      { title: 'SMS Templates', href: '/docs/templates' },
      { title: 'Scheduled SMS', href: '/docs/scheduling' },
    ]
  },
  {
    title: 'API Reference',
    items: [
      { title: 'Authentication', href: '/docs/api/auth' },
      { title: 'Send SMS', href: '/docs/api/send-sms' },
      { title: 'Message Status', href: '/docs/api/status' },
      { title: 'Webhooks', href: '/docs/api/webhooks' },
      { title: 'Client SDKs', href: '/docs/api/sdks' },
    ]
  },
  {
    title: 'Guides',
    items: [
      { title: 'Docker Deployment', href: '/docs/guides/docker' },
      { title: 'Nginx Reverse Proxy', href: '/docs/guides/nginx' },
      { title: 'Multi-tenant Setup', href: '/docs/guides/multi-tenant' },
    ]
  },
]

const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || 'Vendel Documentation'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:wght@400;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title} - Vendel Docs</title>
  </head>
  <body class="antialiased">
    <div class="min-h-screen flex flex-col">
      <!-- Header -->
      <header class="sticky top-0 z-50 bg-[#edf5f1]/95 backdrop-blur-sm border-b border-neutral-200">
        <div class="max-w-[90rem] mx-auto px-6 lg:px-8">
          <nav class="flex items-center justify-between h-14">
            <div class="flex items-center gap-4 md:gap-8">
              <a href="/" class="flex items-baseline">
                <span class="text-[#2dd4a8] text-lg font-bold relative -top-[0.15em]">:</span>
                <span class="font-serif font-bold text-lg tracking-tight uppercase">Vendel</span>
                <span class="text-[#2dd4a8] text-lg font-bold relative -top-[0.15em]">:</span>
              </a>
              <a href="/docs" class="hidden sm:block text-sm font-medium text-neutral-600 hover:text-neutral-900 transition-colors">
                Docs
              </a>
            </div>

            <!-- Desktop menu -->
            <div class="hidden md:flex items-center gap-4">
              <a href="https://github.com/JimScope/vendel" class="text-neutral-600 hover:text-neutral-900 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                </svg>
              </a>
              <button onclick="openWaitlistModal()" class="btn btn-primary">
                Dashboard
                <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </button>
            </div>

            <!-- Mobile menu button -->
            <button id="docs-mobile-menu-btn" class="md:hidden p-2 -mr-2 text-neutral-600 hover:text-neutral-900 transition-colors" aria-label="Open menu">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path id="docs-menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                <path id="docs-menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </nav>

          <!-- Mobile menu -->
          <div id="docs-mobile-menu" class="hidden md:hidden pb-4 border-t border-neutral-200 pt-4">
            <div class="flex flex-col gap-4">
              <a href="/docs" class="text-neutral-600 hover:text-neutral-900 transition-colors text-sm font-medium">
                Docs
              </a>
              <a href="https://github.com/vendel-sms" class="text-neutral-600 hover:text-neutral-900 transition-colors text-sm font-medium">
                GitHub
              </a>
              <button onclick="openWaitlistModal()" class="btn btn-primary w-full justify-center">
                Dashboard
                <svg class="btn-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </header>

      <div class="flex-1 max-w-[90rem] mx-auto w-full flex">
        <!-- Sidebar -->
        <aside class="hidden lg:block w-64 shrink-0 border-r border-neutral-200">
          <nav class="sticky top-14 p-6 h-[calc(100vh-3.5rem)] overflow-y-auto flex flex-col">
            <div class="flex-1">
              {sidebar.map((section) => (
                <div class="mb-6">
                  <h3 class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-3">
                    {section.title}
                  </h3>
                  <ul class="space-y-1">
                    {section.items.map((item) => (
                      <li>
                        <a
                          href={item.href}
                          class:list={[
                            'block py-1.5 px-3 text-sm rounded-lg transition-colors',
                            currentPath === item.href || currentPath === item.href + '/'
                              ? 'bg-neutral-900 text-white'
                              : 'text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100'
                          ]}
                        >
                          {item.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
            <!-- LLM-friendly docs -->
            <div class="pt-4 mt-4 border-t border-neutral-200">
              <a
                href="/llms.txt"
                class="flex items-center gap-2 text-xs text-neutral-500 hover:text-neutral-700 transition-colors"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                llms.txt
              </a>
            </div>
          </nav>
        </aside>

        <!-- Main content -->
        <main class="flex-1 min-w-0 px-6 lg:px-12 py-8 lg:py-12">
          <article class="prose prose-neutral max-w-3xl prose-headings:font-serif prose-h1:text-4xl prose-h1:mb-4 prose-h2:border-b prose-h2:border-neutral-200 prose-h2:pb-2 prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-code:bg-neutral-200 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none prose-pre:bg-neutral-900 prose-pre:text-neutral-200 prose-th:bg-bg prose-td:border-neutral-200 prose-th:border-b-2 prose-th:border-neutral-300">
            <slot />
          </article>
        </main>
      </div>
    </div>
    <WaitlistModal />
  </body>
</html>

<script>
  const menuBtn = document.getElementById('docs-mobile-menu-btn');
  const mobileMenu = document.getElementById('docs-mobile-menu');
  const iconOpen = document.getElementById('docs-menu-icon-open');
  const iconClose = document.getElementById('docs-menu-icon-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');

    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    } else {
      mobileMenu?.classList.remove('hidden');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    }
  });

  // Close menu when clicking a link
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>

<style is:global>
  /* Lead text for documentation intro paragraphs */
  .prose .lead {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  /* Use JetBrains Mono for all code */
  .prose code,
  .prose pre code {
    font-family: var(--font-mono);
  }

  /* Fix code inside pre to not have background */
  .prose pre code {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
  }
</style>
