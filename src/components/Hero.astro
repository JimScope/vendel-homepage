---
// Generate random positions for accent dots
const accentDots = [
    { top: "15%", left: "5%" },
    { top: "25%", left: "20%" },
    { top: "35%", left: "12%" },
    { top: "45%", left: "25%" },
    { top: "55%", left: "8%" },
    { top: "20%", left: "45%" },
    { top: "40%", left: "50%" },
    { top: "60%", left: "42%" },
    { top: "30%", left: "75%" },
    { top: "50%", left: "80%" },
    { top: "70%", left: "70%" },
    { top: "15%", left: "90%" },
    { top: "45%", left: "88%" },
    { top: "65%", left: "95%" },
];
---

<section class="relative min-h-[80vh] dot-pattern overflow-hidden">
    <!-- Accent dots scattered across the background -->
    {
        accentDots.map((dot) => (
            <div
                class="absolute w-3 h-3 bg-[#2dd4a8] rounded-full"
                style={`top: ${dot.top}; left: ${dot.left};`}
            />
        ))
    }

    <div class="max-w-7xl mx-auto px-6 lg:px-8 pt-16 lg:pt-24">
        <div class="max-w-4xl mx-auto text-center">
            <h1
                class="font-serif text-4xl sm:text-5xl lg:text-[3.5rem] font-bold text-neutral-900 leading-[1.1]"
            >
                Open source SMS gateway.<br class="hidden lg:block" /> Build with your own devices.
            </h1>
            <p class="mt-6 text-lg text-neutral-600 max-w-lg mx-auto">
                Self-hosted API to send SMS using Android phones or modems.
                No third-party APIs, no per-message fees.
            </p>
            <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
                <a
                    href="https://app.vendel.cc"
                    class="btn btn-primary"
                >
                    Get Started
                    <svg
                        class="btn-icon"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
                <a href="/docs" class="btn btn-link">
                    Read the docs
                    <svg
                        class="btn-icon"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                </a>
            </div>
            <div class="mt-4 flex justify-center">
                <a href="https://www.producthunt.com/products/vendel?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-vendel" target="_blank" rel="noopener noreferrer">
                    <img alt="Vendel - An open source SMS gateway for your own devices | Product Hunt" width="200" height="43" src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1119265&theme=dark&t=1775687211131" />
                </a>
            </div>

        </div>
    </div>
</section>
